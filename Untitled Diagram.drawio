  <diagram name="Page-1" id="21VVTi6LkBdTKDMymRsY">
    <mxGraphModel dx="2785" dy="1403" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n56Nwd96kQem_y__6VAz-13" edge="1" parent="1" source="n56Nwd96kQem_y__6VAz-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="n56Nwd96kQem_y__6VAz-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;center&quot;&gt;&amp;nbsp; I want to scan an old hard drive enclosure for a server.&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;center&quot;&gt;I want to make some changes and print out a few cheap prototype and use them as reference to finalize the design.&amp;nbsp;&lt;/div&gt;&lt;div align=&quot;center&quot;&gt;Then I want to print a high quality version&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="210" x="100" y="30" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-44" edge="1" parent="1" source="n56Nwd96kQem_y__6VAz-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="n56Nwd96kQem_y__6VAz-15">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-51" edge="1" parent="1" source="n56Nwd96kQem_y__6VAz-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;fillColor=#d5e8d4;strokeColor=#000000;endArrow=none;endFill=0;" target="n56Nwd96kQem_y__6VAz-34">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=0;align=center;" value="&lt;b&gt;Step 1: 3D Scanner&lt;/b&gt;&lt;br&gt;&lt;div&gt;Scan the old hard drive enclosure to create a digital 3D model.&lt;/div&gt;&lt;div align=&quot;left&quot;&gt;&amp;nbsp;Duration: 2h&lt;/div&gt;&lt;div&gt;&lt;div align=&quot;left&quot;&gt;&amp;nbsp;Booking required: Yes&lt;br&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;&lt;b&gt;Step 2: Fusion 360&lt;/b&gt;&lt;br&gt;Import the scanned data, convert to a solid model, and design the necessary modifications for the new enclosure version.&lt;br&gt;&lt;div align=&quot;left&quot;&gt;&lt;div align=&quot;left&quot;&gt;&amp;nbsp;Duration: 8h&lt;/div&gt;&lt;div&gt;&lt;div align=&quot;left&quot;&gt;&amp;nbsp;Booking required: No&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 25px;&quot;&gt;&lt;b&gt;...&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 25px;&quot;&gt;&lt;b&gt;...&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;b&gt;Step 9: UV Curing Station&lt;/b&gt;&lt;br&gt;Post-cure the SLA printed part to achieve final material properties and strength.&lt;br&gt;&lt;div align=&quot;left&quot;&gt;&lt;div align=&quot;left&quot;&gt;&lt;div align=&quot;left&quot;&gt;&amp;nbsp;Duration: 3h&lt;/div&gt;&lt;div&gt;&lt;div align=&quot;left&quot;&gt;&amp;nbsp;Booking required: Yes&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;&lt;b&gt;Step 10:&amp;nbsp;&lt;/b&gt;&lt;br&gt;Perform a final quality inspection, on the high-quality printed enclosure.&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;b&gt;TOTAL COST : €295&lt;/b&gt;" vertex="1">
          <mxGeometry height="370" width="430" x="-10" y="200" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-33" edge="1" parent="1" source="n56Nwd96kQem_y__6VAz-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="n56Nwd96kQem_y__6VAz-26">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;" value="&lt;div&gt;Have the scanning on monday after lunch&lt;/div&gt;&lt;div&gt;Make the inital prints early in the week&lt;/div&gt;I want to do the final print during the weekend and use the curing station close to&lt;br&gt;&amp;nbsp;that time" vertex="1">
          <mxGeometry height="110" width="220" x="890" y="230" as="geometry" />
        </mxCell>
        <mxCell id="n56Nwd96kQem_y__6VAz-8" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;" value="&lt;div align=&quot;center&quot;&gt;Steps requiring booking (4):&lt;br&gt;&lt;div align=&quot;justify&quot;&gt;&lt;b&gt;&amp;nbsp; Step 1&lt;/b&gt;: 3D Scanner - 2h&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;justify&quot;&gt;&amp;nbsp;&lt;b&gt; Step 4:&lt;/b&gt; FDM 3D Printer - 12h&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;justify&quot;&gt;&amp;nbsp;&lt;b&gt; Step 8&lt;/b&gt;: SLA 3D Printer - 10h&lt;br&gt;&lt;/div&gt;&lt;div align=&quot;justify&quot;&gt;&lt;b&gt;&amp;nbsp; Step 9: &lt;/b&gt;UV Curing Station - 1h&lt;br&gt;&lt;/div&gt;&lt;br&gt;Enter booking preferences&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="210" x="890" y="60" as="geometry" />
        </mxCell>
